---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 4em 0 2em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.3em;
			}
			.hero p {
				font-size: 1.1em;
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.hero-links {
				display: flex;
				gap: 1em;
				flex-wrap: wrap;
			}
			.hero-links a {
				text-decoration: none;
				color: var(--accent);
				font-weight: 600;
			}
			.hero-links a:hover {
				text-decoration: underline;
			}
			.writing h2 {
				font-size: 1.2em;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				padding: 0.75em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1em;
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				text-decoration: none;
				color: rgb(var(--black));
				font-weight: 500;
			}
			.post-list a:hover {
				color: var(--accent);
			}
			.post-date {
				font-size: 0.85em;
				color: rgb(var(--gray));
				white-space: nowrap;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Jason Caserta</h1>
				<p>Software developer. I build things for the web.</p>
				<div class="hero-links">
					<a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/blog`}>Writing →</a>
					<a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/about`}>About</a>
					<a href="https://github.com/jasoncaserta" target="_blank">GitHub</a>
				</div>
			</div>

			{posts.length > 0 && (
				<section class="writing">
					<h2>Recent Writing</h2>
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/blog/${post.id}/`}>{post.data.title}</a>
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</li>
						))}
					</ul>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
