---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SocialImage from '../assets/social-share.png';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — Jason Caserta" description="About Jason Caserta" image={SocialImage} />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<p>
				I'm Jason, a software developer based in New York. I like building useful things and
				putting them on the internet.
			</p>
			<p>
				Most recently I built <a href="https://pickgpu.com">PickGPU</a>, a GPU shopping assistant
				that aggregates benchmarks and live pricing from six retailers and ranks cards by
				FPS-per-dollar value. It runs a FastAPI backend on AWS with a React + TypeScript frontend.
			</p>
			<p>
				You can find more of my work on <a href="https://github.com/jasoncaserta">GitHub</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
