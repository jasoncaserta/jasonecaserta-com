---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';

const { pathname } = Astro.url;
const isActive = pathname === '/' || pathname === import.meta.env.BASE_URL;
---

<header>
	<nav>
		<h2><a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/`} class:list={[{ active: isActive }]}>{SITE_TITLE}</a></h2>
		<div class="right-side">
			<div class="internal-links">
				<HeaderLink href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/blog`}>Blog</HeaderLink>
				<HeaderLink href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/about`}>About</HeaderLink>
			</div>
			<div class="social-links">
				<ThemeToggle />
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: white;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 5%);
		transition: background 0.3s ease;
	}
	:global(.dark) header {
		background: #151819;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 20%);
	}
	nav {
		display: flex;
		align-items: stretch;
		justify-content: space-between;
		padding: 0 1em;
	}
	.right-side {
		display: flex;
		align-items: stretch;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		display: flex;
	}
	h2 a {
		padding: 1em 0.5em;
		display: flex;
		align-items: center;
		text-decoration: none;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		transition: border-color 0.2s ease;
		margin-bottom: -1px;
		line-height: 1;
	}
	h2 a.active {
		border-bottom-color: var(--accent);
		font-weight: 700;
	}
	.internal-links {
		display: flex;
		align-items: stretch;
	}
	.social-links {
		display: flex;
		align-items: stretch;
		margin-left: 0.5em;
	}
	.social-links a {
		display: flex;
		align-items: center;
		padding: 1em 0.5em;
		color: rgb(var(--black));
		line-height: 1;
	}
	@media (max-width: 720px) {
		.social-links a:not(#themeToggle) {
			display: none;
		}
	}
</style>
